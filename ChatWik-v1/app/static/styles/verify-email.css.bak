body{
    margin: 0px;
    padding: 0px;
}
body .container{
    border-radius: 10px;
    background-color: rgb(245, 245, 240);
    box-shadow: 5px 5px 3px rgb(178, 179, 180);
    width: 50%;
    margin-top: 80px;
}
.container .form-control{
    padding: 20px;
    border: none;
    border-radius: 5px;
}

#head{
    border-bottom: 1px solid grey;
    margin-top: 25px;
    margin-bottom: 10px;
}
.container #head p{
    margin-bottom: 10px;
    font-size: 15px;
    text-align: center;
}
.container #head h2{
    text-align: center;
}
.container span {
    font-size: 20px;
    color: red;
}
.container #form .grp-btn{
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
}
